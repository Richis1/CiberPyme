# Configuración de Django (Ejemplo)
# Copia este archivo como '.env' en la raíz de tu proyecto y configura los valores.

# Clave secreta para cifrado y sesiones (Genera una clave larga y aleatoria en producción)
SECRET_KEY=django-insecure-prod-key-cambiame-en-produccion-12345

# Modo depuración: False en producción para seguridad y rendimiento
DEBUG=True

# Hosts autorizados a los que el sitio responderá (separados por comas)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Base de datos (opcional, si no se especifica usará db.sqlite3 por defecto)
# Ejemplo para PostgreSQL: postgres://usuario:contraseña@host:puerto/nombre_bd
# DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Orígenes confiables para CSRF en producción (separados por comas)
# CSRF_TRUSTED_ORIGINS=https://tu-app-en-render.onrender.com,https://tudominio.com
